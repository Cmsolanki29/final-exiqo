DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartspend_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT auth (required in production — use a long random string)
JWT_SECRET_KEY=xxx
# Optional overrides (defaults: access 7d, refresh 30d)
# JWT_ACCESS_MINUTES=10080
# JWT_REFRESH_DAYS=30

# CORS — browser origins allowed to call the API (comma-separated).
# Default in code already includes :3000 and :3005 for localhost + 127.0.0.1.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3005,http://127.0.0.1:3005

# CRA frontend (this repo is react-scripts, not Next). Point to your API:
# REACT_APP_API_URL=http://127.0.0.1:8000/api

# Local debugging: return real DB/auth errors in signup/signin JSON (do not enable in production)
# SMARTSPEND_DEBUG_AUTH=1

# Groq — LLM for FraudShield, purchase planner, festival planner, EMI/subscriptions/dark-pattern advice (see backend/services/ai_service.py)
GROQ_API_KEY=your_groq_api_key_here

# Optional — OpenAI (or compatible) for /api/insights (GPT features in openai_service.py). Not the same as Groq.
# OPENAI_API_KEY=your_openai_or_compatible_key_here
# Optional: llama-3.1-8b-instant, llama-3.3-70b-versatile, etc.
# GROQ_MODEL=llama-3.1-8b-instant

# ── Admin auth ───────────────────────────────────────────────────────────────
# Phase 1-12 admin endpoints accept this header value as `X-Admin-Token`.
ADMIN_TOKEN=dev-admin-secret
# audit-8 (additive JWT path): comma-separated integer user_ids that count
# as admins when authenticating Phase 9-12 admin routes via
# `Authorization: Bearer <jwt>`.  Phase 1-8 routes still use ADMIN_TOKEN
# only.  Empty = no JWT-admin path; X-Admin-Token still works.
ADMIN_USER_IDS=
