# Points the React app at the live backend with Phase 10-12 routes active.
# Port 8001 is used because the old stale uvicorn workers (pre-Phase-10 code)
# are occupying port 8000 with zombie sockets that Windows hasn't released.
# Run the backend with:  uvicorn main:app --host 127.0.0.1 --port 8001
REACT_APP_API_URL=http://localhost:8001/api
